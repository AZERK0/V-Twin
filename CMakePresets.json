{
  "version": 3,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 19,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "linux-base",
      "hidden": true,
      "generator": "Unix Makefiles",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_POLICY_VERSION_MINIMUM": "3.5",
        "DISCORD_ENABLED": "OFF",
        "ENGINE_SIM_DATA_ROOT": "${sourceDir}",
        "ENGINE_SIM_BUILD_TESTS": "ON"
      }
    },
    {
      "name": "linux-release",
      "inherits": "linux-base"
    },
    {
      "name": "linux-debug",
      "inherits": "linux-base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "linux-release-fast",
      "inherits": "linux-base",
      "cacheVariables": {
        "ENGINE_SIM_BUILD_TESTS": "OFF"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "build-release",
      "configurePreset": "linux-release",
      "targets": [
        "engine-sim-app"
      ]
    },
    {
      "name": "build-debug",
      "configurePreset": "linux-debug",
      "targets": [
        "engine-sim-app"
      ]
    },
    {
      "name": "build-tests",
      "configurePreset": "linux-release",
      "targets": [
        "engine-sim-test"
      ]
    }
  ],
  "testPresets": [
    {
      "name": "test-release",
      "configurePreset": "linux-release",
      "output": {
        "outputOnFailure": true
      }
    }
  ]
}
